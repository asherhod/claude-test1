# Copy this file to .env.local (gitignored, matched by the *.local rule in
# .gitignore) and fill in real values. See ../supabase-config.js for the
# current local Supabase instance's URL/anon key (start it first with
# `cd ../supabase-local && npx supabase start`).
#
# These are meant to be public/client-visible by design -- access control is
# enforced by Postgres Row Level Security, not by keeping the anon key secret.
# Never put a service_role key here.

VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=replace-with-the-anon-key-from-npx-supabase-status
